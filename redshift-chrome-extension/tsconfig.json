{
  "compilerOptions": {
    "target":            "ES2020",
    "module":            "ES2020",
    "moduleResolution":  "bundler",
    "lib":               ["ES2020", "DOM"],
    "strict":            true,
    "noImplicitAny":     true,
    "noUnusedLocals":    false,
    "noUnusedParameters":false,
    "esModuleInterop":   true,
    "allowSyntheticDefaultImports": true,
    "outDir":            "./dist",
    "rootDir":           "./src",
    "sourceMap":         true,
    "declaration":       false,
    "skipLibCheck":      true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
