# RedShift / SOC Dashboard — Ficheiro de configuração centralizado
# Carregado automaticamente pelo shared_config.py (python-dotenv ou parser manual)
# Prioridade: variáveis já definidas no sistema operativo não são sobrescritas.
# ─────────────────────────────────────────────────────────────────────────────

# ── SSE Server (Dashboard) ────────────────────────────────────────────────────
PORT=5001                            # Porta do servidor SSE
DASHBOARD_HOST=localhost             # Host de escuta
DASHBOARD_THEME=dark                 # dark | light

# ── Janela temporal ───────────────────────────────────────────────────────────
DASHBOARD_WINDOW_DAYS=1              # Janela principal em dias
WINDOW_HOURS=24                      # = DASHBOARD_WINDOW_DAYS × 24
STEP_HOURS=1                         # Passo de agregação (deve dividir WINDOW_HOURS)
MIN_ALERTS_WINDOW=3                  # Mínimo de alertas por janela para análise
DEFAULT_ACTIVE_WINDOW_MINUTES=15     # Janela ativa por omissão (minutos)

# ── Dashboard UI ──────────────────────────────────────────────────────────────
DASHBOARD_UPDATE_INTERVAL_MS=5000    # Refresh rate do dashboard (ms)
DASHBOARD_HISTORY_LIMIT=200          # Máx. alertas em memória
DASHBOARD_AGENT2_REPORTS_LIMIT=20    # Máx. relatórios Agent 2 a listar
DASHBOARD_TIMEOUT_UNIT_MINUTES=15    # Unidade de timeout do dashboard

# ── Backend FastAPI / uvicorn ─────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1
BACKEND_WORKERS=1
BACKEND_LOG_LEVEL=warning            # debug | info | warning | error

# ── Texer — servidor LaTeX → PDF ──────────────────────────────────────────────
TEXER_HOST=localhost                 # Host do servidor texer
TEXER_PORT=5002                      # Porta Flask do texer
TEXER_COMPILE_TIMEOUT=60             # Timeout pdflatex (segundos)
TEXER_COMPILE_RUNS=2                 # Passes de compilação (2 para cross-refs)

# ── Agent 2 ───────────────────────────────────────────────────────────────────
AGENT2_POLL_SECONDS=5                # Intervalo de polling (segundos)
AGENT2_RUN_ONCE=0                    # 1 = executa uma vez; 0 = loop contínuo
AGENT2_TIMEOUT_SECONDS=300           # Timeout por relatório (s) — aumente para Ollama
AGENT2_CVE_CODES=                    # CVEs adicionais separados por vírgula (opcional)
AGENT2_DEBUG=0                       # 1 = logs detalhados do Agent 2

# ── LLM — tuning ─────────────────────────────────────────────────────────────
AGENT2_MAX_TOKENS=1800               # Máx. tokens na resposta LLM (Agent 2)
AGENT2_TEMPERATURE=0.3               # 0.0 = determinístico · 1.0 = criativo

# LLM Melhorias
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL_SECONDS=3600
LLM_QUALITY_METRICS_ENABLED=true
LLM_COT_ENABLED=true
LLM_CROSS_VALIDATION=false  # true = mais lento, mais preciso
LLM_COMPLEXITY_HIGH=0.8
LLM_COMPLEXITY_MEDIUM=0.5

# ── LLM — logging ────────────────────────────────────────────────────────────
LITELLM_LOG=ERROR                    # DEBUG | INFO | WARNING | ERROR — lido directamente pelo llm_engine.py
LITELLM_VERBOSE=false                 # lido directamente pelo llm_engine.py
LOG_LEVEL=INFO                       # Nível de log global

# ── LLM — providers ──────────────────────────────────────────────────────────
# Agent 1: classificação ENISA→CISO (peso em latência → preferir ollama/local)
LLM_PROVIDER=ollama                  # none | ollama | anthropic | openai

# Agent 2: análise 360° e geração de relatório (peso em qualidade → preferir anthropic)
LLM_PROVIDER2=anthropic              # none | ollama | anthropic | openai

# ── Ollama (local) ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2                # mistral | llama3.2 | phi3 | gemma2 | etc.
OLLAMA_AUTO_PULL=1                   # 1 = pull automático se modelo ausente
OLLAMA_START_WAIT_S=15               # Segundos de espera para o Ollama arrancar

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OpenAI / LiteLLM genérico ────────────────────────────────────────────────
OPENAI_API_KEY=                      # sk-... (obrigatório se provider=openai)
LITELLM_MODEL=gpt-4o-mini            # Modelo Agent 1 via LiteLLM
LITELLM_MODEL2=gpt-4o-mini           # Modelo Agent 2 via LiteLLM

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=UTC                               # Recomendado UTC para consistência entre agentes

# ── CISO Window (janela flutuante trigger-based) ──────────────────────────────
CISO_WINDOW_MINUTES=15               # Duração da janela em modo 'fixed'
CISO_WINDOW_LOOKBACK=true            # Janela olha para trás do timestamp trigger
CISO_WINDOW_FORWARD=false            # Janela olha para frente do timestamp trigger
CISO_MIN_ALERTS_PER_WINDOW=1         # Mínimo de alertas para classificar

TRIGGER_ON_WINDOW_EXPIRY=true        # Gera trigger quando janela expira sem novos alertas
TRIGGER_EXPIRY_BUFFER_SECONDS=5      # Buffer anti-duplicação após expiração
WINDOW_OVERLAP_RATIO=0.5             # Sobreposição entre janelas (0=nenhuma · 1=total)

CISO_DECISION_TIMEOUT_SECONDS=120    # Timeout para confirmação manual (segundos)
CISO_DECISION_ENABLED=true           # Activar mecanismo de confirmação manual

# ── Streaming — simulação de replay ──────────────────────────────────────────
STREAM_TIMEOUT_MINUTES=15            # Timeout total de streaming
STREAM_STEP_MINUTES=15               # Passo de actualização de streaming
# Ratio tempo simulado / tempo real entre alertas:
# 0.01 = 100× mais rápido  |  0.05 = 20×  |  0.5 = 2×  |  1.0 = tempo real
STREAM_SPEED_FACTOR=0.5

# ── Window mode ───────────────────────────────────────────────────────────────
# fixed    = duração constante CISO_WINDOW_MINUTES para todos os alertas
# adaptive = duração variável por fase do trigger (RECON=5m … IMPACT=30m)
WINDOW_MODE=adaptive

# ── Hypothesis Graph ──────────────────────────────────────────────────────────
CONFIRMATION_THRESHOLD=0.85          # Score mínimo para confirmar hipótese (0.5–0.99)
HYPOTHESIS_DECAY_HOURS=24.0          # Decaimento de score ao longo do tempo (horas)
MAX_PARALLEL_WINDOWS=10              # Máx. janelas activas em simultâneo
CONVERGENCE_STD_THRESHOLD=0.05       # Threshold de convergência de probabilidades
INCOHERENCE_THRESHOLD=0.3            # Threshold de incoerência entre hipóteses

# ── Classificador probabilístico ─────────────────────────────────────────────
PROBABILISTIC_VARIANCE=0.10          # Variância de perturbação nas probabilidades
PROBABILISTIC_MAX_HYPOTHESES=3       # Máx. hipóteses CISO por janela (cardinalidade n)
PROBABILISTIC_TIMEOUT_AUTO=true      # Auto-confirmação por timeout