title Dashboard Frontend — Pipeline de Render (UML 2.x, swimlanes)

|main.ts|
start
:Trigger de render:\nSSE event recebido\nOU user interaction\nOU timer tick;

:renderFull();

fork
  |alert_timeline.ts|
  :updateTimelineDisplay()\n→ getAlerts()\n→ renderAlertTimelineSVG(\n    alerts, height=72,\n    selectedAlertNumber,\n    onAlertClick → extension\n  )\n→ innerHTML do #timeline-content\n→ auto-scroll para o fim;
fork again
  |windows_panel.ts|
  :renderWindowsPanel(\n  _activeWindows, nowMs\n);
  :Filtrar: alert_count > 0;
  :Separar ACTIVAS / FECHADAS;
  note right
    Card ACTIVA (4 linhas):
    1. 🕐 09:00→09:19 📊N Score:N ⏱
    2. 🎯 N Fases: Ph→Ph
    3. Alert Timeline SVG
    4. Hipóteses com botões CR/HI%
    ─────────────────────────────
    Card FECHADA (minimal):
    09:00→09:05 [85% Hypothesis] [📊N]
    + badge ✋/⏱/⚡
  end note
  :→ innerHTML do #windows-panel;
fork again
  |graph_viz.ts|
  :renderHypothesisGraph(\n  _graphState\n)\n→ SVG do grafo de hipóteses\n→ nós coloridos por tier\n→ edges ponderadas\n→ innerHTML do #hypothesis-graph;
fork again
  |agent2.ts|
  :renderAgent2Panel(\n  [], 0,\n  agent2Reports,\n  {}\n);
  :Para cada report:;
  :card com label, tier, %,\n methodIcon (✋/⏱/⚡),\n windowCtx (alertas, score,\n fases, timestamps)\n→ botão ⊞ abre relatório PDF;
  :→ innerHTML do #agent2-panel;
fork again
  |slice.ts|
  :syncSliceInputs()\nupdateSliceLabels()\nupdateCurrentAlertDisplay()\n→ DOM do slicer temporal;
fork again
  |sidebar.ts kpi.ts footer.ts|
  :renderSidebarKPIs()\nrenderKPIStrip()\nrenderScoreFilter()\nrenderConnectionBadge()\n→ DOM das secções auxiliares;
end fork

|main.ts|
:_activeWindows\n  .filter(w => !w.is_closed)\n  .forEach(_pushWindowContextToExtension);
if (prob_top ≥ 75%\nAND NOT in _pushedToExtension?) then (sim)
  :window.postMessage(\n  REDSHIFT_WINDOW_CONTEXT, '*'\n)\n→ Chrome Extension;
else (não)
end if

:_updatePendingBadge()\nbadge ⏳ N em fila;

stop
@enduml


