package "src/boot" {
  component [template.ts\nAPP_TEMPLATE HTML] as TMPL
}

package "src/core" {
  component [store.ts\nEstado global reactivo] as STORE
  component [types.ts\nInterfaces TypeScript] as TYPES
  component [logger.ts\nLogger estruturado] as LOG
  component [constants.ts\nSTORAGE_KEYS] as CONST
}

package "src/data" {
  component [handlers.ts\ncomputeKPIs()] as HAND
}

package "src/components" {
  component [main.ts\nOrchestrador SSE + Render] as MAIN
  component [windows_panel.ts\nrenderWindowsPanel()] as WP
  component [agent2.ts\nrenderAgent2Panel()] as A2
  component [alert_timeline.ts\nrenderAlertTimelineSVG()] as AT
  component [slice.ts\nControlo de ritmo\n+ Slicer temporal] as SL
  component [graph_viz.ts\nrenderHypothesisGraph()] as GV
  component [sidebar.ts\nrenderSidebarKPIs()] as SB
  component [kpi.ts\nrenderKPIStrip()] as KPI
  component [modals.ts\nrenderDetailModal()] as MOD
  component [footer.ts\nrenderConnectionBadge()] as FOOT
}

package "src/extension" {
  component [content.ts\n__wmPushAlertToExtension\nwindow.postMessage()] as CONT
}

package "Servidor SSE :5001" {
  component [SSE Broker\n/events] as SSE
  interface "GET /events" as ISSE
  interface "POST /api/agent1/*" as IAPI
  SSE - ISSE
  SSE - IAPI
}

' Dependências
MAIN --> TMPL : <<imports>>
MAIN --> STORE : <<imports>>\ngetAlerts, setConnection\ngetAgent2Reports...
MAIN --> TYPES : <<imports>>\nWindowState, AlertPayload...
MAIN --> LOG : <<imports>>
MAIN --> HAND : computeKPIs()
MAIN --> WP : renderWindowsPanel()
MAIN --> A2 : renderAgent2Panel()
MAIN --> AT : renderAlertTimelineSVG()
MAIN --> SL : wireSliceControls()\nstartCountdown()
MAIN --> GV : renderHypothesisGraph()
MAIN --> SB : renderSidebarKPIs()
MAIN --> KPI : renderKPIStrip()
MAIN --> MOD : renderDetailModal()
MAIN --> FOOT : renderConnectionBadge()

WP --> TYPES : <<imports>>
WP --> AT : renderAlertTimelineSVG()\n(mini-timeline nos cards)
WP --> CONT : window.postMessage()\n__wmPushAlertToExtension()
A2 --> TYPES : <<imports>>
AT --> TYPES : <<imports>>
SL --> TYPES : <<imports>>

MAIN --> ISSE : new EventSource()\nconectaSSE()
MAIN --> IAPI : POST process-next\nPOST confirm-hypothesis\nPOST seek\nPOST finish

note right of STORE
  Estado global:
  • alerts: AlertPayload[]
  • activeWindows: WindowState[]
  • agent2Reports: Agent2Report[]
  • graphState: HypothesisGraphState
  • connection: string
  • sliceState: SliceState
  Persistido em sessionStorage
end note

note right of MAIN
  Ponto de entrada único.
  Orquestra:
  • SSE event loop
  • Render pipeline
  • Timer management
  • Extension push
  • User events
end note
@enduml


