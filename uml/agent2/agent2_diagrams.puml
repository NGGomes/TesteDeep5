    end note
  }

  node "Agent 1\nProcesso: agent1/main.py" as A1_NODE {
    component [HypothesisGraph\n(Singleton partilhado)] as HG
    artifact "hypothesis_graph.json" as HGFILE
    artifact "dataset.txt\n(alertas de entrada)" as DS
  }

  node "reports/" as REPORTS {
    artifact "agent2/\ngraph_report_*.json" as JSON
    artifact "agent2/\ngraph_report_*_ciso.pdf" as RPDF
    artifact "agent2/\ngraph_report_*_soc.pdf" as RSPDF
    artifact "agent1/\n.pending_queue.json" as RQUEUE
  }

}

node "LLM Runtime\n(local ou remoto)" as LLM_NODE {
  component [Ollama :11434\n/ Anthropic API\n/ OpenAI API] as LLM
}

node "Browser" as BROWSER {
  component [Dashboard SPA] as DASH
}

' Dependências internas
GR ..> HG : <<shared memory>>\nget_global_graph()\npoll 2s
GR --> SSE_NODE : POST :5001/ingest\nciso_report event
GR --> TEX_NODE : POST :5002/generate\n{tex content}
GR ..> DS : lê via AlertLoader\nna startup

' Artefactos
GR -down-> QFILE : persiste fila
TEX -down-> CPDF : gera
TEX -down-> SPDF : gera
CG --> CTEX : gera .tex
SG --> STEX : gera .tex
GR -down-> JSON : _save_report()
CPDF -down-> RPDF : copia para reports/
SPDF -down-> RSPDF : copia para reports/
QFILE -down-> RQUEUE : partilhado

' LLM
IA --> LLM : POST HTTP\nLLM_PROVIDER2\n(ollama/anthropic/openai)

' Browser
SSE_NODE --> BROWSER : GET :5001/events\nSSE stream
DASH --> SSE_NODE : POST :5001/api/agent1/confirm-hypothesis

note right of GR
  Garantia de entrega:
  1. _enqueue() persiste antes de gerar
  2. _dequeue_success() só após emit ok
  3. Restart restaura .pending_queue.json
  4. Poll loop reprocessa falhas
end note
@enduml
